<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Flowlog" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="TodoWidgetRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="TodoWidgetTitle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#202124</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TodoWidgetTime">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#777777</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TodoWidgetSmallButton">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:textSize">11sp</item>
    </style>
</resources>
