<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/todo_widget_item_root"
    style="@style/TodoWidgetRow">

    <TextView
        android:id="@+id/todo_widget_item_title"
        style="@style/TodoWidgetTitle" />

    <TextView
        android:id="@+id/todo_widget_item_time"
        style="@style/TodoWidgetTime" />

    <Button
        android:id="@+id/todo_widget_item_start"
        style="@style/TodoWidgetSmallButton"
        android:text="&#xC2DC;&#xC791;" />

    <Button
        android:id="@+id/todo_widget_item_done"
        style="@style/TodoWidgetSmallButton"
        android:text="&#xC644;&#xB8CC;" />
</LinearLayout>
